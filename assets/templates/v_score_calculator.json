        {
          "score": 4,
          "description": "良好时机",
          "indicators": [
            "政策环境有利",
            "资金渠道畅通",
            "客户有明确时间计划",
            "市场竞争适中"
          ]
        },
        {
          "score": 3,
          "description": "一般时机",
          "indicators": [
            "政策环境平稳",
            "资金来源有保障",
            "客户时间要求一般",
            "市场竞争正常"
          ]
        },
        {
          "score": 2,
          "description": "较差时机",
          "indicators": [
            "政策窗口即将关闭",
            "资金申报刚结束",
            "客户时间要求不紧迫",
            "市场竞争激烈"
          ]
        },
        {
          "score": 1,
          "description": "不佳时机",
          "indicators": [
            "政策红利期已过",
            "资金渠道不畅",
            "客户无明确计划",
            "市场已饱和"
          ]
        }
      ]
    },
    {
      "id": "S",
      "name": "Synergy",
      "label": "业务协同度",
      "description": "能否带动机构内部3个及以上业务部门参与？",
      "weight": 1,
      "scoring_criteria": [
        {
          "score": 5,
          "description": "极高协同度",
          "indicators": [
            "可带动5个及以上业务部门",
            "形成完整业务链条",
            "各部门均有实质性参与",
            "产生显著协同效应"
          ]
        },
        {
          "score": 4,
          "description": "高协同度",
          "indicators": [
            "可带动4个业务部门",
            "业务链条较完整",
            "各部门参与度较高",
            "协同效应明显"
          ]
        },
        {
          "score": 3,
          "description": "中等协同度",
          "indicators": [
            "可带动3个业务部门",
            "业务链条基本完整",
            "各部门有一定参与度",
            "有一定协同效应"
          ]
        },
        {
          "score": 2,
          "description": "较低协同度",
          "indicators": [
            "可带动2个业务部门",
            "业务链条不完整",
            "主业务部门和辅助部门",
            "协同效应有限"
          ]
        },
        {
          "score": 1,
          "description": "低协同度",
          "indicators": [
            "仅涉及1个业务部门",
            "单一业务类型",
            "无协同效应"
          ]
        }
      ]
    }
  ],
  "evaluation_matrix": {
    "20": {
      "level": "极高价值",
      "action": "必须拿下",
      "description": "战略级项目，投入最优资源全力争取"
    },
    "16-19": {
      "level": "高价值",
      "action": "优先推进",
      "description": "优质项目，优先配置资源重点跟进"
    },
    "12-15": {
      "level": "中高价值",
      "action": "积极争取",
      "description": "良好项目，积极争取合理投入"
    },
    "8-11": {
      "level": "中等价值",
      "action": "选择性跟进",
      "description": "一般项目，根据资源情况选择性跟进"
    },
    "4-7": {
      "level": "较低价值",
      "action": "谨慎评估",
      "description": "低价值项目，谨慎评估后决定是否跟进"
    },
    "1-3": {
      "level": "低价值",
      "action": "建议放弃",
      "description": "价值较低，建议放弃或等待时机"
    }
  },
  "usage_guide": {
    "steps": [
      {
        "step": 1,
        "action": "逐条阅读各维度的评分标准",
        "tip": "理解每个分数档位的具体含义"
      },
      {
        "step": 2,
        "action": "根据项目实际情况，为每个维度打分",
        "tip": "可参考评分标准中的指标描述"
      },
      {
        "step": 3,
        "action": "计算总分 V = I + C + T + S",
        "tip": "各维度分数相加得出总分"
      },
      {
        "step": 4,
        "action": "对照评估矩阵，确定项目价值等级",
        "tip": "根据总分确定后续行动策略"
      },
      {
        "step": 5,
        "action": "记录评分理由，形成评估文档",
        "tip": "便于后续复盘和团队沟通"
      }
    ],
    "notes": [
      "评分应基于客观事实，避免主观臆断",
      "可邀请多位同事独立评分后讨论确定",
      "评分结果应定期复盘，根据实际情况调整",
      "V公式评分是决策参考，非唯一依据"
    ]
  },
