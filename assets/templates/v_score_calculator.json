{
  "name": "V公式评分计算器",
  "version": "1.0.0",
  "description": "用于评估项目机会价值的V公式评分工具配置",
  "formula": "V = I + C + T + S",
  "threshold": {
    "high_value": 12,
    "medium_value": 8,
    "low_value": 0
  },
  "dimensions": [
    {
      "id": "I",
      "name": "Impact",
      "label": "战略影响力",
      "description": "项目能否写入政府工作报告？能否成为区域标杆？",
      "weight": 1,
      "scoring_criteria": [
        {
          "score": 5,
          "description": "极高影响力",
          "indicators": [
            "可写入省级政府工作报告",
            "可成为国家级示范/试点",
            "具有行业标杆意义",
            "媒体关注度高，品牌效应显著"
          ]
        },
        {
          "score": 4,
          "description": "高影响力",
          "indicators": [
            "可写入市级政府工作报告",
            "可成为省级示范/试点",
            "在区域内具有引领作用",
            "对机构品牌有显著提升"
          ]
        },
        {
          "score": 3,
          "description": "中等影响力",
          "indicators": [
            "可写入区县级政府工作报告",
            "可成为市级示范/试点",
            "在行业内具有一定知名度",
            "对机构品牌有正面影响"
          ]
        },
        {
          "score": 2,
          "description": "较低影响力",
          "indicators": [
            "可作为部门重点工作",
            "在局部区域有影响力",
            "对机构品牌影响有限"
          ]
        },
        {
          "score": 1,
          "description": "低影响力",
          "indicators": [
            "常规性项目",
            "影响力局限于项目本身",
            "对机构品牌无明显贡献"
          ]
        }
      ]
    },
    {
      "id": "C",
      "name": "Connection",
      "label": "诉求连接度",
      "description": "是否直接解决核心决策者（如书记、市长）的KPI或痛点？",
      "weight": 1,
      "scoring_criteria": [
        {
          "score": 5,
          "description": "极高连接度",
          "indicators": [
            "直接解决一把手（书记/市长）的核心KPI",
            "解决客户最紧迫、最痛的问题",
            "客户有强烈意愿和明确预算",
            "项目成功对客户仕途有重要影响"
          ]
        },
        {
          "score": 4,
          "description": "高连接度",
          "indicators": [
            "直接解决分管领导的核心KPI",
            "解决客户的重要痛点",
            "客户有明确需求和预算计划",
            "项目成功对客户考核有重要影响"
          ]
        },
        {
          "score": 3,
          "description": "中等连接度",
          "indicators": [
            "解决部门负责人的工作任务",
            "解决客户的一般性需求",
            "客户有需求但预算不确定",
            "项目对考核有一定影响"
          ]
        },
        {
          "score": 2,
          "description": "较低连接度",
          "indicators": [
            "解决业务层面的常规需求",
            "对客户有一定帮助但非必需",
            "预算不明确或有限",
            "项目对考核影响较小"
          ]
        },
        {
          "score": 1,
          "description": "低连接度",
          "indicators": [
            "锦上添花型项目",
            "客户需求不明确",
            "无明确预算来源",
            "项目对考核无直接影响"
          ]
        }
      ]
    },
    {
      "id": "T",
      "name": "Timing",
      "label": "时间匹配度",
      "description": "是否契合政策窗口期和资金申报节奏？",
      "weight": 1,
      "scoring_criteria": [
        {
          "score": 5,
          "description": "极佳时机",
          "indicators": [
